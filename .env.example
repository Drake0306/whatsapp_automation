# ── Database (Railway MySQL) ──
DATABASE_URL="mysql://root:password@host:port/railway"

# ── Auth.js ──
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_TRUST_HOST=true

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email (magic link) — for local dev use Mailpit: docker compose up -d → http://localhost:8025
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@whatsappflow.app"

# ── Cloudflare R2 ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="whatsappflow-uploads"

# ── WhatsApp ──
WHATSAPP_MODE="bsp"                           # "bsp" or "direct"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_APP_SECRET=""
WHATSAPP_API_TOKEN=""
WHATSAPP_API_URL="https://graph.facebook.com/v22.0"
WHATSAPP_BSP_API_URL=""                       # BSP-specific URL (if different)

# ── Cron (Railway cron service auth) ──
CRON_SECRET=""

# ── Razorpay ──
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ── Super Admin ──
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD="change-this-password"
SUPER_ADMIN_EMAILS="admin@example.com"

# ── LLM Providers ──
GEMINI_API_KEY=""
SARVAM_API_KEY=""
GROQ_API_KEY=""
ANTHROPIC_API_KEY=""
